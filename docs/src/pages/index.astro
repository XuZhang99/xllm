---
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const defaultLocalePath = `${basePath}/en/`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta http-equiv="refresh" content={`0;url=${defaultLocalePath}`} />
		<meta name="robots" content="noindex" />
		<link rel="canonical" href={defaultLocalePath} />
		<title>Redirecting to English docs</title>
		<script is:inline define:vars={{ defaultLocalePath }}>
			window.location.replace(defaultLocalePath);
		</script>
	</head>
	<body>
		<a href={defaultLocalePath}>Redirecting to English docs</a>
	</body>
</html>
